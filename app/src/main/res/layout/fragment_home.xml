<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textHomeGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/woofie_primary_dark"
            android:textSize="30sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/woofie_surface"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/woofie_primary"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/imageWolf"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/woofie_wolf" />

                <TextView
                    android:id="@+id/textHomeProfession"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:textColor="@color/woofie_text_primary"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/textHomeStreak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_woofie_outline"
            android:padding="14dp"
            android:textColor="@color/woofie_primary_dark"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonStartLesson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/woofie_accent"
            android:text="@string/home_start_lesson"
            android:textAllCaps="false"
            android:textColor="@color/woofie_primary_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonOpenProgress"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/home_open_progress"
            android:textAllCaps="false"
            android:textColor="@color/woofie_primary_dark"
            app:strokeColor="@color/woofie_primary" />
    </LinearLayout>
</ScrollView>

