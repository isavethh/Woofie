<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_woofie_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonPlacementBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/placement_back"
                android:src="@drawable/ic_arrow_back" />

            <TextView
                android:id="@+id/textPlacementTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:textColor="@color/woofie_primary_dark"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textPlacementProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/woofie_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/placementProgressBar"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="6dp"
            app:indicatorColor="@color/woofie_primary"
            app:trackColor="@color/woofie_gray_200"
            app:trackCornerRadius="6dp" />

        <ImageView
            android:id="@+id/placementHero"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:contentDescription="@string/wolf_content_description"
            android:src="@drawable/woofie_wolf" />

        <TextView
            android:id="@+id/textPlacementHeadline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/woofie_primary_dark"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textPlacementSubhead"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/woofie_text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textPlacementQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/woofie_primary_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/placementOptionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOption1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="56dp"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOption2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="56dp"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOption3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="56dp"
                android:textAllCaps="false" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonOption4"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="56dp"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/textPlacementFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/woofie_text_primary"
            android:textStyle="bold"
            android:visibility="gone" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/placementBadges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:singleLine="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonPlacementPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:backgroundTint="@color/woofie_accent"
            android:textAllCaps="false"
            android:textColor="@color/woofie_primary_dark" />
    </LinearLayout>
</ScrollView>

