<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="8dp">

    <FrameLayout
        android:id="@+id/nodeAnchor"
        android:layout_width="match_parent"
        android:layout_height="86dp">

        <View
            android:id="@+id/nodeShadow"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/lesson_node_locked"
            android:alpha="0.25"
            android:translationY="6dp" />

        <TextView
            android:id="@+id/textNodeBadge"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/lesson_node_unlocked"
            android:gravity="center"
            android:textColor="@color/woofie_primary_dark"
            android:textStyle="bold" />
    </FrameLayout>

    <View
        android:id="@+id/pathConnector"
        android:layout_width="8dp"
        android:layout_height="34dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/woofie_primary_light" />
</LinearLayout>

