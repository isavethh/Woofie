<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Woofie" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/woofie_primary_light</item>
        <item name="colorPrimaryVariant">@color/woofie_primary_dark</item>
        <item name="colorOnPrimary">@color/woofie_primary_dark</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/woofie_accent</item>
        <item name="colorSecondaryVariant">@color/woofie_accent_strong</item>
        <item name="colorOnSecondary">@color/woofie_primary_dark</item>
        <item name="colorSurface">@color/woofie_primary_dark</item>
        <item name="android:colorBackground">@color/woofie_primary_dark</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <!-- Customize your theme here. -->
    </style>
</resources>